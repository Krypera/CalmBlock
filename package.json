{
  "name": "calmblock",
  "version": "0.1.1",
  "description": "CalmBlock is a calm, privacy-first browser extension for blocking ads, trackers, and common annoyances.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "funding": {
    "type": "other",
    "url": "https://github.com/Krypera/CalmBlock/blob/main/SUPPORT.md"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src tests scripts",
    "lint:fix": "biome lint --write src tests scripts",
    "rules:build": "node scripts/build-rules.mjs",
    "ci:smoke": "node scripts/smoke-dist.mjs all",
    "e2e:browser:setup": "npx playwright install chromium firefox",
    "e2e:browser:chrome": "node scripts/e2e-browser.mjs chrome --strict",
    "e2e:browser:firefox": "node scripts/e2e-browser.mjs firefox --strict",
    "e2e:browser": "node scripts/e2e-browser.mjs all",
    "e2e:browser:strict": "node scripts/e2e-browser.mjs all --strict",
    "build": "node scripts/build.mjs all",
    "build:chrome": "node scripts/build.mjs chrome",
    "build:firefox": "node scripts/build.mjs firefox",
    "safari:plan": "node scripts/build-safari.mjs --plan",
    "package:chrome": "npm run build:chrome && node scripts/package.mjs chrome",
    "package:firefox": "npm run build:firefox && node scripts/package.mjs firefox",
    "package:all": "npm run build && node scripts/package.mjs all",
    "dev:chrome": "node scripts/build.mjs chrome --watch",
    "dev:firefox": "node scripts/build.mjs firefox --watch",
    "test": "vitest run --no-file-parallelism",
    "test:coverage": "vitest run --no-file-parallelism --coverage",
    "test:watch": "vitest",
    "clean": "node scripts/clean.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^3.2.4",
    "archiver": "^7.0.1",
    "esbuild": "^0.25.4",
    "jsdom": "^26.1.0",
    "playwright": "^1.55.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
